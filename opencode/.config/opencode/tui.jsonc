{
  "$schema": "https://opencode.ai/tui.json",

  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "pwd": "allow",
      "git status": "allow",
      "cat": "allow"
    }
  },

  // UI theme used by the TUI.
  // tokyonight matches Neovim users well since many already use this theme.
  "theme": "tokyonight"

}
